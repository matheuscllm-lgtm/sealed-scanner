# Python cache
__pycache__/
*.pyc
*.pyo

# Secrets — NEVER commit
.env
.env.*
!.env.example
*.pem
credentials.json

# Playwright session profiles (binary state)
.pw_profile_*/

# Scanner outputs (data, logs, debug artifacts)
*.xlsx
*.log
*.html
# fixtures de teste são versionadas (HTML estável p/ travar seletores)
!tests/fixtures/*.html
*_cache.json

# Run artifacts (cada scan escreve um dir timestamped fresco)
results/
.config_local_run.yaml

# Local-only operational / strategy notes (kept on disk, not published)
snapshots/
GOALS.md
AGENT.md
RUNBOOK.md
docs/SESSION-*.md
docs/HANDOFF-*.md
docs/archive/

# Watchdog runtime lock (PID + heartbeat — nunca commitar)
.watchdog.lock

# Draft intermediário do gerador de registry
scripts/registry_additions.yaml
